{
    "servers": {
        "github": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
            }
        },
        "playwright": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@anthropic/mcp-server-playwright"
            ]
        },
        "filesystem": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@anthropic/mcp-server-filesystem",
                "${workspaceFolder}"
            ]
        },
        "memory": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@anthropic/mcp-server-memory"
            ]
        },
        "fetch": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@anthropic/mcp-server-fetch"
            ]
        }
    }
}